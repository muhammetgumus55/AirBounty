# ─────────────────────────────────────────────
#  DroneChain – Environment Variables
#  Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────

# ── Smart Contract ────────────────────────────
# Deployed address of DroneTask.sol on Monad Testnet
NEXT_PUBLIC_CONTRACT_ADDRESS=

# ── Monad Network ─────────────────────────────
# RPC endpoint for Monad Testnet (default is the public endpoint)
NEXT_PUBLIC_MONAD_RPC=https://testnet-rpc.monad.xyz

# ── AI Verification ───────────────────────────
# OpenRouter API key – used SERVER-SIDE ONLY in API routes
# Never prefix with NEXT_PUBLIC_
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: choose provider/model via OpenRouter
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
